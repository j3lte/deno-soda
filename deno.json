{
  "name": "@j3lte/soda",
  "version": "0.4.6",
  "license": "MIT",
  "exports": "./mod.ts",
  "publish": {
    "exclude": [
      "test/",
      "scripts/",
      ".github/",
      "CLAUDE.md"
    ]
  },
  "tasks": {
    "format": "deno fmt ./src/ ./test/ ./scripts/",
    "lint": "deno lint ./src/ ./test/ ./scripts/",
    "test": "deno test --coverage=.coverage",
    "coverage": "deno coverage .coverage --lcov --exclude=/test/ --exclude=/scripts/ > ./.coverage/coverage.lcov",
    "test:watch": "deno test --watch",
    "clean": "rm -r ./coverage",
    "local-test": "deno run --allow-read --allow-write --allow-run ./scripts/run-test.ts",
    "set-version": "deno run --allow-read --allow-write ./scripts/set-version.ts",
    "doc-coverage": "deno run --allow-run ./scripts/doc-coverage.ts",
    "npm": "deno run -A ./scripts/build-npm.ts"
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "singleQuote": false,
    "useTabs": false,
    "proseWrap": "preserve",
    "exclude": [
      ".coverage/",
      "npm/",
      ".github/",
      "README.md"
    ]
  },
  "lint": {
    "rules": {
      "include": [
        "ban-untagged-todo",
        "explicit-function-return-type"
      ]
    },
    "exclude": [
      "npm/"
    ]
  },
  "test": {
    "exclude": [
      "npm/",
      ".coverage/"
    ]
  },
  "exclude": [
    "npm/",
    ".coverage/",
    ".github/"
  ],
  "imports": {
    "@deno/dnt": "jsr:@deno/dnt@^0.42.3",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/testing": "jsr:@std/testing@^1.0.19"
  }
}
